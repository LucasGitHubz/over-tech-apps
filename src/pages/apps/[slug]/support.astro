---
import { apps } from "../../../data/apps";

export function getStaticPaths() {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

const { app } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Support | {app.name}</title>
    <meta name="description" content={`Support page for ${app.name}`} />
  </head>

  <body>
    <main class="page">
      <a href={`/apps/${app.slug}`}>← Back to {app.name}</a>

      <h1>Support</h1>
      <p class="intro">
        Need help with {app.name}? You can contact Over Tech Apps using the email below.
      </p>

      <section class="card">
        <h2>Contact support</h2>
        <p>
          Email:
          <a href={`mailto:${app.supportEmail}`}>{app.supportEmail}</a>
        </p>
        <p>
          Please include the app name, your device model, iOS version, and a short
          description of the issue.
        </p>
      </section>

      <section>
        <h2>Useful links</h2>
        <ul>
          <li><a href={`/apps/${app.slug}/privacy`}>Privacy Policy</a></li>
          <li><a href={`/apps/${app.slug}/terms`}>Terms of Use</a></li>
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #0f172a;
    color: #e5e7eb;
  }

  .page {
    width: min(820px, calc(100% - 40px));
    margin: 0 auto;
    padding: 48px 0;
  }

  h1 {
    font-size: clamp(42px, 7vw, 72px);
    letter-spacing: -0.05em;
    margin: 56px 0 16px;
  }

  h2 {
    margin-top: 40px;
  }

  p,
  li {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .intro {
    font-size: 20px;
  }

  .card {
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 24px;
    padding: 24px;
    margin-top: 32px;
    background: rgba(15, 23, 42, 0.75);
  }

  a {
    color: #38bdf8;
    font-weight: 700;
  }
</style>