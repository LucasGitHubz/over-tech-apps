---
import { apps } from "../../../data/apps";

export function getStaticPaths() {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

const { app } = Astro.props;
const lastUpdated = "May 31, 2026";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Terms of Use | {app.name}</title>
    <meta name="description" content={`Terms of Use for ${app.name}`} />
  </head>

  <body>
    <main class="page">
      <a href={`/apps/${app.slug}`}>← Back to {app.name}</a>

      <h1>Terms of Use</h1>
      <p class="muted">Last updated: {lastUpdated}</p>

      <section>
        <h2>Use of the App</h2>
        <p>
          By using {app.name}, you agree to use the app responsibly and only for lawful purposes.
        </p>
      </section>

      <section>
        <h2>Availability</h2>
        <p>
          Over Tech Apps aims to keep the app available and functional, but does not guarantee
          that the app will always be available, error-free, or uninterrupted.
        </p>
      </section>

      <section>
        <h2>No Warranty</h2>
        <p>
          {app.name} is provided “as is”, without warranties of any kind, unless required by law.
        </p>
      </section>

      <section>
        <h2>Changes</h2>
        <p>
          These Terms of Use may be updated from time to time. Continued use of the app means
          you accept the updated terms.
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          For questions about these terms, contact:
          <a href={`mailto:${app.supportEmail}`}>{app.supportEmail}</a>
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #0f172a;
    color: #e5e7eb;
  }

  .page {
    width: min(820px, calc(100% - 40px));
    margin: 0 auto;
    padding: 48px 0;
  }

  h1 {
    font-size: clamp(42px, 7vw, 72px);
    letter-spacing: -0.05em;
    margin: 56px 0 8px;
  }

  h2 {
    margin-top: 40px;
  }

  p {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .muted {
    color: #94a3b8;
  }

  a {
    color: #38bdf8;
    font-weight: 700;
  }
</style>