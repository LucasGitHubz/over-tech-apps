---
import { apps } from "../../../data/apps";

export function getStaticPaths() {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

const { app } = Astro.props;
const lastUpdated = "May 31, 2026";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Privacy Policy | {app.name}</title>
    <meta name="description" content={`Privacy Policy for ${app.name}`} />
  </head>

  <body>
    <main class="page">
      <a href={`/apps/${app.slug}`}>← Back to {app.name}</a>

      <h1>Privacy Policy</h1>
      <p class="muted">Last updated: {lastUpdated}</p>

      <section>
        <h2>{app.name}</h2>
        <p>
          This Privacy Policy explains how {app.name}, published by Over Tech Apps,
          handles user information.
        </p>
      </section>

      <section>
        <h2>Data Collection</h2>

        {app.privacy.collectsData ? (
          <>
            <p>
              This app may collect information necessary to provide, secure, and improve
              the service.
            </p>

            {app.privacy.hasLogin && (
              <p>
                This app includes a login or account system. Information such as an email
                address, user identifier, or authentication-related data may be used to
                create and manage your account.
              </p>
            )}
          </>
        ) : (
          <p>
            This app does not collect, store, or share personal data from users.
          </p>
        )}
      </section>

      {app.privacy.dataTypes.length > 0 && (
        <section>
          <h2>Types of Data</h2>
          <ul>
            {app.privacy.dataTypes.map((dataType) => (
              <li>{dataType}</li>
            ))}
          </ul>
        </section>
      )}

      {app.privacy.thirdPartyServices.length > 0 && (
        <section>
          <h2>Third-Party Services</h2>
          <p>
            This app may use third-party services to provide certain features, authentication,
            analytics, crash reporting, or backend infrastructure.
          </p>
          <ul>
            {app.privacy.thirdPartyServices.map((service) => (
              <li>{service}</li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2>Children’s Privacy</h2>
        <p>
          This app is not intended to knowingly collect personal information from children
          unless explicitly stated in the app’s specific features and App Store listing.
        </p>
      </section>

      <section>
        <h2>Changes to This Policy</h2>
        <p>
          This Privacy Policy may be updated from time to time. Updates will be published
          on this page with a new “Last updated” date.
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          For privacy questions, contact:
          <a href={`mailto:${app.supportEmail}`}>{app.supportEmail}</a>
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #0f172a;
    color: #e5e7eb;
  }

  .page {
    width: min(820px, calc(100% - 40px));
    margin: 0 auto;
    padding: 48px 0;
  }

  h1 {
    font-size: clamp(42px, 7vw, 72px);
    letter-spacing: -0.05em;
    margin: 56px 0 8px;
  }

  h2 {
    margin-top: 40px;
  }

  p,
  li {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .muted {
    color: #94a3b8;
  }

  a {
    color: #38bdf8;
    font-weight: 700;
  }
</style>