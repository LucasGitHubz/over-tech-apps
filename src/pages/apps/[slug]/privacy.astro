---
import { apps } from "../../../data/apps";

export function getStaticPaths() {
  return apps.map((app) => ({
    params: { slug: app.slug },
    props: { app },
  }));
}

const { app } = Astro.props;
const lastUpdated = "May 31, 2026";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Privacy Policy | {app.name}</title>
    <meta name="description" content={`Privacy Policy for ${app.name}`} />
  </head>

  <body>
    <main class="page">
      <a href={`/apps/${app.slug}`}>← Back to {app.name}</a>

      <h1>Privacy Policy</h1>
      <p class="muted">Last updated: {lastUpdated}</p>

      <section>
        <h2>{app.name}</h2>
        <p>
          This Privacy Policy explains how {app.name}, published by Over Tech Apps,
          handles user information.
        </p>
      </section>

      <section>
        <h2>Data Collection</h2>
        {app.collectsData ? (
          <p>
            This app may collect information necessary to provide and improve the
            service. Details may vary depending on the features used.
          </p>
        ) : (
          <p>
            This app does not collect, store, or share personal data from users.
          </p>
        )}
      </section>

      <section>
        <h2>Third-Party Services</h2>
        <p>
          If third-party services are used in the app, they may process data
          according to their own privacy policies.
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          For privacy questions, contact:
          <a href={`mailto:${app.supportEmail}`}>{app.supportEmail}</a>
        </p>
      </section>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #0f172a;
    color: #e5e7eb;
  }

  .page {
    width: min(820px, calc(100% - 40px));
    margin: 0 auto;
    padding: 48px 0;
  }

  h1 {
    font-size: clamp(42px, 7vw, 72px);
    letter-spacing: -0.05em;
    margin: 56px 0 8px;
  }

  h2 {
    margin-top: 40px;
  }

  p {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .muted {
    color: #94a3b8;
  }

  a {
    color: #38bdf8;
    font-weight: 700;
  }
</style>